{
  "expo": {
    "name": "style_selector",
    "slug": "style_selector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "styleselector",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raniatiesin.styleselector"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FEF4DD",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.raniatiesin.styleselector"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4703db1c-1ba4-45ec-85ec-dabdd8b94ce7"
      }
    },
    "owner": "raniatiesin",
    "updates": {
      "url": "https://u.expo.dev/4703db1c-1ba4-45ec-85ec-dabdd8b94ce7"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
