modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RCT_METRO_PORT=5000 node_modules/.bin/expo start --web --port 5000 --localhost"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "node_modules/.bin/expo export --platform web"]
publicDir = "dist"

[userenv]

[userenv.shared]
EXPO_PUBLIC_SUPABASE_URL = "https://srjhrsfinmrxufncdxbd.supabase.co"
EXPO_PUBLIC_POWERSYNC_URL = "https://6a210ddf0ef84ed6719ed1a2.powersync.journeyapps.com"
